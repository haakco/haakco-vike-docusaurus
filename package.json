{
  "name": "@haakco/vike-plugin-docusaurus",
  "version": "0.1.0",
  "description": "Vike plugin and build helpers for serving a Docusaurus site with Pagefind",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haakco/haakco-vike-docusaurus.git"
  },
  "homepage": "https://github.com/haakco/haakco-vike-docusaurus",
  "bugs": {
    "url": "https://github.com/haakco/haakco-vike-docusaurus/issues"
  },
  "packageManager": "pnpm@10.32.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/root.d.ts",
      "import": "./dist/root.js"
    }
  },
  "bin": {
    "haakco-vike-docusaurus-build": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json --types node",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit --types node",
    "lint": "pnpm run lint:biome && pnpm run lint:complexity && pnpm run lint:dup && pnpm run typecheck",
    "lint:biome": "pnpm exec biome check src package.json tsconfig.json README.md --colors=off",
    "lint:complexity": "pnpm exec biome lint src --colors=off --only=lint/complexity/noExcessiveCognitiveComplexity",
    "lint:dup": "pnpm exec jscpd src README.md package.json tsconfig.json --pattern \"**/*.{ts,md,json}\" --ignore \"**/node_modules/**,**/dist/**\" --min-lines 5 --min-tokens 50 --threshold 0",
    "test": "pnpm exec vitest run"
  },
  "keywords": [
    "vike",
    "vite",
    "docusaurus",
    "pagefind",
    "haakco"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pagefind": "^1.4.0"
  },
  "peerDependencies": {
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.3.0",
    "jscpd": "^4.0.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
